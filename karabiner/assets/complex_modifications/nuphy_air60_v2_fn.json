                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "8", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "play_or_pause" }]
                },
                {
                    "description": "Fn+9 → Next Track",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "9", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
