{
    "title": "NuPhy Air60 V2 Fn Layer",
    "rules": [
        {
            "description": "NuPhy Fn: right_option as Fn key (Esc→`, 1-0→media/brightness, =-→vol, F-keys with shift)",
            "manipulators": [
                {
                    "description": "Fn+Esc → `",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "escape", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "grave_accent_and_tilde" }]
                },
                {
                    "description": "Fn+Shift+Esc → ~",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "escape", "modifiers": { "mandatory": ["right_option", "shift"], "optional": ["caps_lock"] } },
                    "to": [{ "key_code": "grave_accent_and_tilde", "modifiers": ["left_shift"] }]
                },
                {
                    "description": "Fn+1 → Brightness Down",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "1", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "display_brightness_decrement" }]
                },
                {
                    "description": "Fn+2 → Brightness Up",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "2", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "display_brightness_increment" }]
                },
                {
                    "description": "Fn+3 → Mission Control",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "3", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "mission_control" }]
                },
                {
                    "description": "Fn+4 → Spotlight (Cmd+Space)",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "4", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "spacebar", "modifiers": ["left_command"] }]
                },
                {
                    "description": "Fn+5 → Dictation",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "5", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "f5", "modifiers": ["fn"] }]
                },
                {
                    "description": "Fn+6 → Do Not Disturb",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "6", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "shell_command": "shortcuts run 'Toggle Focus'" }]
                },
                {
                    "description": "Fn+7 → Previous Track",
                    "type": "basic",
                    "conditions": [{ "identifiers": [{ "vendor_id": 6645, "product_id": 12885 }], "type": "device_if" }],
                    "from": { "key_code": "7", "modifiers": { "mandatory": ["right_option"], "optional": ["any"] } },
                    "to": [{ "key_code": "rewind" }]
                },
                {
